# Prisma + Railway MySQL (use ONE of these URL vars)
# Railway MySQL service → Variables → copy MYSQL_URL or build manually:
DATABASE_URL=mysql://root:password@containers-us-west-xxx.railway.app:3306/railway
# MYSQL_URL=mysql://root:password@containers-us-west-xxx.railway.app:3306/railway

# Optional: separate mysql2 vars (not needed if DATABASE_URL is set)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=railway
DB_SSL=true

JWT_SECRET=your_secret_key_here_change_in_production
PORT=5000
CLIENT_ORIGIN=http://localhost:5173,https://task-managemnet-system.netlify.app
API_BASE_URL=https://your-railway-backend.up.railway.app
